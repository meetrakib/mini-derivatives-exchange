# Database (defaults work with docker-compose)
POSTGRES_USER=mini_exchange
POSTGRES_PASSWORD=mini_exchange_dev
POSTGRES_DB=mini_exchange

# Optional: connect to quest-saas-api to emit trade events (use a tenant API key)
# GAMIFICATION_API_URL=http://host.docker.internal:8001
# GAMIFICATION_API_KEY=your_tenant_api_key

# Optional: mock starting price for BTC-PERP
# MOCK_PRICE=50000

# JWT for auth (signup/login). Change in production.
# JWT_SECRET=change-me-in-production
# JWT_EXPIRE_MINUTES=10080
